generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  parent
  teacher
  employer
  admin
}

model User {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  passwordHash      String
  role              Role     @default(student)
  grade             Int?
  city              String?
  targetUniversity  String?
  targetSpecialty   String?
  isPremium         Boolean  @default(false)
  streak            Int      @default(0)
  totalStudyMinutes Int      @default(0)
  lastActiveDate    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Parent-child relationship (optional)
  parentId          String?
  parent            User?    @relation("ParentChild", fields: [parentId], references: [id])
  children          User[]   @relation("ParentChild")

  // Relations
  diagnosticResults DiagnosticResult[]
  studyPlans        StudyPlan[]
  moduleProgresses  ModuleProgress[]
  entResults        EntResult[]
  enrollments       CourseEnrollment[]
  lessonCompletions LessonCompletion[]
}

model DiagnosticResult {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject String
  scores  Json     // { score, maxScore, percentage, level, weakTopics, strongTopics }
  takenAt DateTime @default(now())
}

model StudyPlan {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalType         String
  totalModules     Int
  completedModules Int      @default(0)
  weeks            Json     // serialized plan weeks array
  createdAt        DateTime @default(now())
  isActive         Boolean  @default(true)
}

model ModuleProgress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId  String
  answers   Json     @default("{}")
  testScore Int?
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([userId, moduleId])
}

model EntResult {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalScore   Int
  percentage   Float
  blockResults Json     // per-subject breakdown
  takenAt      DateTime @default(now())
}

// Admission deadlines — verified by admin, staleness checked automatically
model AdmissionDeadline {
  id          String    @id @default(cuid())
  entryId     String                          // matches AdmissionEntry.id in frontend data
  label       String
  date        DateTime
  type        String                          // 'application' | 'exam' | 'results' | 'scholarship'
  sourceUrl   String
  verifiedAt  DateTime  @default(now())
  changedFrom DateTime?                       // previous date if auto-updated
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([entryId])
  @@index([date])
}

// ── Course Builder ────────────────────────────────────────────────────────────

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  subject     String   // 'ent' | 'ielts' | 'math' | 'physics' | 'history' | 'english'
  level       String   // 'beginner' | 'intermediate' | 'advanced'
  price       Int      @default(0)
  coverColor  String   @default("#2563eb")
  isPublished Boolean  @default(false)
  modules     CourseModule[]
  enrollments CourseEnrollment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CourseModule {
  id       String   @id @default(cuid())
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  order    Int      @default(0)
  lessons  Lesson[]
}

model Lesson {
  id          String       @id @default(cuid())
  moduleId    String
  module      CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  duration    Int?         // estimated minutes
  order       Int          @default(0)
  blocks      Json         @default("[]") // LessonBlock[]
  completions LessonCompletion[]
}

model CourseEnrollment {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([courseId, userId])
}

model LessonCompletion {
  id          String   @id @default(cuid())
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizScore   Int?
  completedAt DateTime @default(now())

  @@unique([lessonId, userId])
}

// Content managed by admin — IELTS materials, mentor Q&As, vocab, ENT questions, curator topics
model Content {
  id        String   @id @default(cuid())
  type      String   // 'ielts_material' | 'mentor_qa' | 'vocab_word' | 'ent_question' | 'curator_topic'
  data      Json     // flexible payload per type
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
