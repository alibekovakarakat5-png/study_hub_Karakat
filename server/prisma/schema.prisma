generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  student
  parent
  teacher
  employer
  admin
}

model User {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  passwordHash      String
  role              Role     @default(student)
  grade             Int?
  city              String?
  targetUniversity  String?
  targetSpecialty   String?
  isPremium         Boolean  @default(false)
  streak            Int      @default(0)
  totalStudyMinutes Int      @default(0)
  lastActiveDate    String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Telegram bot
  telegramChatId    String?  @unique

  // Password reset
  resetToken        String?  @unique
  resetTokenExp     DateTime?

  // Referral system
  referralCode      String?  @unique
  referredBy        String?

  @@index([createdAt])
  @@index([role])

  // Parent-child relationship (optional)
  parentId          String?
  parent            User?    @relation("ParentChild", fields: [parentId], references: [id])
  children          User[]   @relation("ParentChild")

  // Relations
  diagnosticResults DiagnosticResult[]
  studyPlans        StudyPlan[]
  moduleProgresses  ModuleProgress[]
  entResults        EntResult[]
  enrollments       CourseEnrollment[]
  lessonCompletions LessonCompletion[]
  subscriptions     Subscription[]
  payments          Payment[]

  // Teacher classroom
  taughtClasses     Class[]               @relation("TeacherClasses")
  classMemberships  ClassMembership[]
  givenAssignments  Assignment[]          @relation("TeacherAssignments")
  submissions       AssignmentSubmission[]
}

model DiagnosticResult {
  id      String   @id @default(cuid())
  userId  String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject String
  scores  Json     // { score, maxScore, percentage, level, weakTopics, strongTopics }
  takenAt DateTime @default(now())

  @@index([userId])
  @@index([userId, takenAt])
}

model StudyPlan {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  goalType         String
  totalModules     Int
  completedModules Int      @default(0)
  weeks            Json     // serialized plan weeks array
  createdAt        DateTime @default(now())
  isActive         Boolean  @default(true)

  @@index([userId, isActive])
}

model ModuleProgress {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId  String
  answers   Json     @default("{}")
  testScore Int?
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  @@unique([userId, moduleId])
}

model EntResult {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalScore   Int
  percentage   Float
  blockResults Json     // per-subject breakdown
  takenAt      DateTime @default(now())

  @@index([userId])
  @@index([userId, takenAt])
}

// Admission deadlines — verified by admin, staleness checked automatically
model AdmissionDeadline {
  id          String    @id @default(cuid())
  entryId     String                          // matches AdmissionEntry.id in frontend data
  label       String
  date        DateTime
  type        String                          // 'application' | 'exam' | 'results' | 'scholarship'
  sourceUrl   String
  verifiedAt  DateTime  @default(now())
  changedFrom DateTime?                       // previous date if auto-updated
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([entryId])
  @@index([date])
}

// ── Course Builder ────────────────────────────────────────────────────────────

model Course {
  id          String   @id @default(cuid())
  title       String
  description String
  subject     String   // 'ent' | 'ielts' | 'math' | 'physics' | 'history' | 'english'
  level       String   // 'beginner' | 'intermediate' | 'advanced'
  price       Int      @default(0)
  coverColor  String   @default("#2563eb")
  isPublished Boolean  @default(false)
  modules     CourseModule[]
  enrollments CourseEnrollment[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CourseModule {
  id       String   @id @default(cuid())
  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  order    Int      @default(0)
  lessons  Lesson[]

  @@index([courseId])
}

model Lesson {
  id          String       @id @default(cuid())
  moduleId    String
  module      CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  duration    Int?         // estimated minutes
  order       Int          @default(0)
  blocks      Json         @default("[]") // LessonBlock[]
  completions LessonCompletion[]

  @@index([moduleId])
}

model CourseEnrollment {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([courseId, userId])
  @@index([userId])
}

model LessonCompletion {
  id          String   @id @default(cuid())
  lessonId    String
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizScore   Int?
  completedAt DateTime @default(now())

  @@unique([lessonId, userId])
  @@index([userId])
}

// ── Billing ───────────────────────────────────────────────────────────────────

model Plan {
  id          String   @id @default(cuid())
  name        String
  description String   @default("")
  price       Int      // KZT per period
  period      String   // "month" | "year" | "forever"
  features    Json     @default("[]") // { text: string, included: boolean }[]
  isActive    Boolean  @default(true)
  isPopular   Boolean  @default(false)
  badge       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  planId    String
  status    String   // "active" | "expired" | "cancelled" | "trial"
  startsAt  DateTime @default(now())
  expiresAt DateTime
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     Plan      @relation(fields: [planId], references: [id])
  payments Payment[]

  @@index([userId, status])
  @@index([status])
}

model Payment {
  id             String        @id @default(cuid())
  userId         String
  subscriptionId String?
  amount         Int           // KZT
  currency       String        @default("KZT")
  method         String        // "kaspi" | "transfer" | "cash" | "manual"
  status         String        // "pending" | "success" | "failed" | "refunded"
  reference      String?
  notes          String?
  createdAt      DateTime      @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// One-time token for linking Telegram account to StudyHub account
model TelegramLinkToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   @unique  // 6-digit code shown to user
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ── Growth Assistant ─────────────────────────────────────────────────────────

model Lead {
  id          String   @id @default(cuid())
  name        String
  type        String   // 'center' | 'tutor' | 'school' | 'student' | 'other'
  source      String   // 'telegram' | 'instagram' | 'manual' | 'google_maps'
  contact     String?  // phone / username / link
  description String?
  status      String   @default("new") // 'new' | 'contacted' | 'warm' | 'converted' | 'rejected'
  score       Int      @default(0) // 1–10 quality score
  notes       String?
  tags        Json?    // string[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([type])
}

model GrowthTask {
  id          String    @id @default(cuid())
  title       String
  type        String    // 'grant' | 'hackathon' | 'contest' | 'feature' | 'bug' | 'other'
  description String?
  deadline    DateTime?
  url         String?
  status      String    @default("pending") // 'pending' | 'in_progress' | 'done'
  priority    String    @default("medium")  // 'low' | 'medium' | 'high' | 'urgent'
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([deadline])
}

model ContentIdea {
  id          String    @id @default(cuid())
  type        String    // 'post' | 'reels' | 'story' | 'scenario' | 'carousel'
  platform    String    // 'instagram' | 'tiktok' | 'telegram'
  title       String
  body        String
  tags        Json?     // string[]
  status      String    @default("draft") // 'draft' | 'approved' | 'published' | 'archived'
  scheduledAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([status])
  @@index([platform])
}

model Competitor {
  id          String   @id @default(cuid())
  name        String
  url         String?
  description String?
  features    Json?    // string[]
  pricing     Json?    // { plan: string, price: string }[]
  notes       String?
  lastChecked DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Content managed by admin — IELTS materials, mentor Q&As, vocab, ENT questions, curator topics
model Content {
  id        String   @id @default(cuid())
  type      String   // 'ielts_material' | 'mentor_qa' | 'vocab_word' | 'ent_question' | 'curator_topic' | ...
  data      Json     // flexible payload per type
  active    Boolean  @default(true)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type, active])
  @@index([createdAt])
}

// ── File Uploads ──────────────────────────────────────────────────────────────

model UploadedFile {
  id          String   @id @default(cuid())
  filename    String                              // original filename
  storagePath String                              // relative path in server/uploads/
  mimeType    String
  sizeBytes   Int
  uploadedBy  String                              // userId
  status      String   @default("pending")        // pending | processing | done | error
  courseId     String?                             // linked course if generated
  errorMsg    String?                              // error message if processing failed
  metadata    Json?                                // extra info (page count, etc.)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([uploadedBy])
  @@index([status])
}

// ── Teacher Classroom System ──────────────────────────────────────────────────

model Class {
  id          String   @id @default(cuid())
  name        String
  subject     String
  description String?
  teacherId   String
  teacher     User     @relation("TeacherClasses", fields: [teacherId], references: [id], onDelete: Cascade)
  inviteCode  String   @unique
  members     ClassMembership[]
  assignments Assignment[]
  createdAt   DateTime @default(now())

  @@index([teacherId])
  @@index([inviteCode])
}

model ClassMembership {
  id        String   @id @default(cuid())
  classId   String
  class     Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([classId, studentId])
  @@index([studentId])
}

model Assignment {
  id          String    @id @default(cuid())
  title       String
  description String?
  classId     String
  class       Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId   String
  teacher     User      @relation("TeacherAssignments", fields: [teacherId], references: [id], onDelete: Cascade)
  type        String    // 'test' | 'homework' | 'reading'
  content     Json      // { questions: [] } for test; { text: '' } for others
  dueDate     DateTime?
  submissions AssignmentSubmission[]
  createdAt   DateTime  @default(now())

  @@index([classId])
  @@index([teacherId])
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers      Json
  score        Int?
  feedback     String?
  submittedAt  DateTime   @default(now())

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([assignmentId])
}

// ── Study Abroad Guide ────────────────────────────────────────────────────────

model StudyAbroadCountry {
  id             String   @id @default(cuid())
  countryCode    String   @unique                 // "TR", "CZ", "PL", "KR", "MY", "CN", "RU", "US", "GB", "DE", "CA", "AE"
  nameRu         String
  nameEn         String
  nameKk         String   @default("")
  flagEmoji      String
  region         String                           // "Europe", "Asia", "Middle East", "North America"
  requirements   Json                             // { visa, documents[], language, other }
  universities   Json                             // [{ name, qs, city, tuitionUSD, programs[] }]
  scholarships   Json                             // [{ name, coverage, deadline, url }]
  timeline       Json                             // [{ month, action }]
  costs          Json                             // { tuitionUSD, livingUSD, insuranceUSD }
  languageReqs   Json                             // { primary, tests[], courses }
  mentorWhatsApp String   @default("77075884651")
  isActive       Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
