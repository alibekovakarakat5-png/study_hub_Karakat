# ── Database ───────────────────────────────────────────────────────────────────
# Local PostgreSQL:
#   DATABASE_URL="postgresql://postgres:password@localhost:5432/studyhub"
# Docker (run: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=password postgres):
#   DATABASE_URL="postgresql://postgres:password@localhost:5432/studyhub"
# Cloud (Neon.tech, Railway, Supabase — free tier available):
#   DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"
DATABASE_URL="postgresql://postgres:password@localhost:5432/studyhub"

# ── Auth ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-me-to-a-strong-random-secret-at-least-32-chars"

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL="http://localhost:5173"
