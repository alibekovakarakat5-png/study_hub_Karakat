# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://studyhub:STRONG_PASSWORD@localhost:5432/studyhub

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
JWT_SECRET=GENERATE_WITH__openssl_rand_-base64_32

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://studyhub.kz

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=bot_token_from_botfather
TELEGRAM_ADMIN_CHAT_ID=your_telegram_chat_id

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Email (для сброса пароля) ─────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=gmail_app_password
SMTP_FROM=StudyHub <no-reply@studyhub.kz>

# ── Kaspi Pay ─────────────────────────────────────────────────────────────────
KASPI_MERCHANT_ID=your_merchant_id
KASPI_SECRET_KEY=your_secret_key
