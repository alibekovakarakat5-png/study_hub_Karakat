# ── Docker Compose — copy this to .env and fill in values ─────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_PASSWORD=your_strong_password_here

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate a random secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here

# URL фронтенда (для CORS) — домен вашего сервера
FRONTEND_URL=https://studyhub.kz

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_personal_chat_id
TELEGRAM_CHANNEL_ID=-1001234567890

# ── AI ────────────────────────────────────────────────────────────────────────
# Groq (бесплатный): https://console.groq.com → API Keys
GROQ_API_KEY=gsk_...

# Anthropic (если используется): https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Мониторинг (опционально) ──────────────────────────────────────────────────
SENTRY_DSN=

# ── Frontend (Vite — вшивается в сборку) ──────────────────────────────────────
VITE_BASE_URL=https://studyhub.kz
VITE_GA_ID=G-XXXXXXXXXX
